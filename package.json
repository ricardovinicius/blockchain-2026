{
  "name": "aula-1-hello-web3",
  "version": "1.0.0",
  "private": true,
  "description": "Hello World Web3 — Hardhat + Smart Contract + Frontend + MetaMask (aula didática)",
  "scripts": {
    "chain": "hardhat node",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "frontend": "node frontend.js",
    "frontend:dev": "browser-sync start --serveStatic frontend --port 3000 --watch --files frontend --open false"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^5.0.0",
    "browser-sync": "^3.0.4",
    "hardhat": "^2.22.0"
  },
  "dependencies": {
    "express": "^4.21.0"
  }
}
